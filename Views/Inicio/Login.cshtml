
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login</title>
    <link rel="stylesheet" href="~/css/Auth.css" asp-append-version="true" />
</head>
<body>

    <div class="container">
        <div class="auth-form">
            <div class="header-form">
                Login
            </div>
            <div class="body-form">
                <form asp-controller="Inicio" asp-action="Login" method="post" class="form">
                        <input class="form-control mb-3" type="text" placeholder="Correo" name="correo"/>
                        <input class="form-control mb-3" type="password" placeholder="Contraseña" name="clave" />

                        @if (ViewData["Mensaje"] != null)
                        {
                            <div class="alert" role="alert">
                                @ViewData["Mensaje"]
                            </div>
                        }

                        <button class="btn-submit" type="submit" >Iniciar sesion</button>
                </form>
                <div class="footer-form">
                    ¿No tienes una cuenta? <a href="@Url.Action("Register", "Inicio")">Registrate aquí</a>
                </div>
            </div>
            
        </div>
    </div>

    @*<div class="container mt-5 pt-5">
