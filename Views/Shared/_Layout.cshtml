<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ContactOS</title>
    @*<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />*@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppContactos.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-item app-name"><h1>ContactOS</h1></div>
            <div class="nav-item user-info">
                @*<div class="profile">@ViewData["NombreUsuario"].ToString().ToUpper()[0]</div>*@
                <div class="profile">L</div>
                @ViewData["NombreUsuario"]
            </div>
            <div class="nav-item menu">
            <div class="add-user"><a asp-area="" asp-controller="Home" asp-action="CerrarSesion"><img src="~/Images/AddUser.svg"/></a></div>
            <div class="add-user"><a asp-area="" asp-controller="Note" asp-action="SaveNote"><img src="~/Images/AddNote.svg"/></a></div>
            <div class="add-user"><a asp-area="" asp-controller="Home" asp-action="CerrarSesion"><img src="~/Images/AddDate.svg"/></a></div>
            <div class="close-session"><a asp-area="" asp-controller="Home" asp-action="CerrarSesion"><img src="~/Images/Exit.svg"/></a></div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
            @*@RenderSection("Notas")*@
        </main>
    </div>

    @*<footer style="text-align: center;">
            &copy; 2023 - ContactOS - Luis Mendoza
    </footer>*@
    @*<script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>*@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
